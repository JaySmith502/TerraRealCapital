# ─────────────────────────────────────────────────────────────────────────────
# Terra Real Capital Research Tool — environment variables (TEMPLATE)
#
# Copy this file to `.env` and fill in real values:
#     Copy-Item .env.example .env      # Windows PowerShell
#     cp .env.example .env             # macOS / Linux
#
# WHERE THESE VALUES ARE USED:
#   • `.env`                      -> local dev + `uv run pytest` (read by trc/config.py)
#   • `.streamlit/secrets.toml`   -> running the Streamlit app locally
#   • Streamlit Community Cloud   -> app → Settings → Secrets (deployment)
# The values are identical in all three places; only the file format differs.
#
# NEVER commit a filled-in `.env` or any real key. Only this `.example` is tracked.
# How to obtain the Supabase values: see docs/SUPABASE_SETUP.md
# ─────────────────────────────────────────────────────────────────────────────

# --- Supabase (data store) ---
# Project URL, e.g. https://abcdefghijklmn.supabase.co
SUPABASE_URL=

# Supabase **service_role** secret (Project Settings → API → service_role).
# ADMIN key — bypasses row security. Server-side ONLY. Never put in a browser,
# never commit. (This app does NOT use the anon key or Supabase Auth.)
SUPABASE_SERVICE_ROLE_KEY=

# --- Perplexity (city research — one API call per scan) ---
# Create at https://www.perplexity.ai/settings/api   (looks like: pplx-...)
PERPLEXITY_API_KEY=

# --- Anthropic / Claude (report writing — one API call per scan) ---
# Create at https://console.anthropic.com/ → API Keys   (looks like: sk-ant-...)
ANTHROPIC_API_KEY=

# --- App access ---
# Single shared password that gates the whole tool. Pick something strong and
# share it with the team via a password manager (never chat/email).
APP_PASSWORD=

# --- Optional model overrides (defaults shown; uncomment ONLY to change) ---
#PERPLEXITY_MODEL=sonar-pro
#CLAUDE_MODEL=claude-sonnet-4-6
